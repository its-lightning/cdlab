#include <iostream>
#include <vector>
#include <string>
#include <iomanip>
using namespace std;

struct Statement {
    string op;
    string arg1;
    string arg2;
    string result;
};

Statement parse(const string &line) {
    Statement s;
    string expr = "";
    for (char c : line) if (c != ' ') expr += c;

    size_t eq = expr.find('=');
    s.result = expr.substr(0, eq);
    string rhs = expr.substr(eq + 1);

    string ops = "+-*/";
    int opPos = -1;
    for (int i = 1; i < (int)rhs.size(); i++) {
        for (char op : ops) {
            if (rhs[i] == op) {
                opPos = i;
                break;
            }
        }
        if (opPos != -1) break;
    }

    if (opPos == -1) {
        s.op = "=";
        s.arg1 = rhs;
        s.arg2 = "-";
    } else {
        s.op = string(1, rhs[opPos]);
        s.arg1 = rhs.substr(0, opPos);
        s.arg2 = rhs.substr(opPos + 1);
    }

    return s;
}

void printRow(vector<string> cols, int w) {
    for (auto &c : cols)
        cout << left << setw(w) << c;
    cout << "\n";
}

void printLine(int n) {
    cout << string(n, '-') << "\n";
}

int main() {
    int n;
    cout << "Enter number of statements: ";
    cin >> n;
    cin.ignore();

    vector<Statement> stmts(n);
    cout << "Enter the statements:\n";
    for (int i = 0; i < n; i++) {
        string line;
        getline(cin, line);
        stmts[i] = parse(line);
    }

    int w = 10;

    // Quadruple
    cout << "\nQuadruple\n";
    printRow({"Op", "Arg1", "Arg2", "Result"}, w);
    printLine(w * 4);
    for (auto &s : stmts)
        printRow({s.op, s.arg1, s.arg2, s.result}, w);

    // Triple
    cout << "\nTriple\n";
    printRow({"Index", "Op", "Arg1", "Arg2"}, w);
    printLine(w * 4);
    for (int i = 0; i < stmts.size(); i++)
        printRow({to_string(i), stmts[i].op, stmts[i].arg1, stmts[i].arg2}, w);

    // Indirect Triple
    cout << "\nIndirect Triple\n";
    printRow({"Pointer", "Index"}, w);
    printLine(w * 2);
    for (int i = 0; i < stmts.size(); i++)
        printRow({to_string(i), to_string(i)}, w);

    return 0;
}
